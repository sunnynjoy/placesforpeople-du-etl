# Copy this to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (it contains secrets)

gcp_project_id = "your-gcp-project-id"
gcp_region     = "us-central1"

service_name      = "du-etl"
image_name        = "du-etl"
image_tag         = "latest"
db_instance_name  = "du-chapters-db"
db_name           = "du_chapters"
db_user           = "du_user"
db_password       = "CHANGE_ME_TO_STRONG_PASSWORD"

schedule_expression = "0 2 * * *"  # Daily at 2 AM UTC
state_filter        = "CA"
log_level           = "INFO"
